{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile in Barda system with associated role and permissions",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "passwordHash": { "type": "string" },
        "role": { "type": "string", "enum": ["Administrador", "Vendedor", "Taller", "Administrativo", "Personalizado"] },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "name", "email", "role", "permissions", "createdAt"]
    },
    "Invitation": {
      "title": "Invitation",
      "description": "User invite system bypass codes generated by administrators",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "name": { "type": "string" },
        "code": { "type": "string" },
        "role": { "type": "string", "enum": ["Administrador", "Vendedor", "Taller", "Administrativo", "Personalizado"] },
        "status": { "type": "string", "enum": ["pendiente", "aceptada"] },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "email", "name", "code", "role", "permissions", "status", "createdAt"]
    },
    "SalesOrder": {
      "title": "SalesOrder",
      "description": "A confirmed sales order, generated from a quote",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "orderNum": { "type": "string" },
        "total": { "type": "number" },
        "senaAmount": { "type": "number" },
        "paymentStatus": { "type": "string" },
        "status": { "type": "string" },
        "notes": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "total"]
    },
    "FixedCost": {
      "title": "FixedCost",
      "description": "A business expense or recurring utility cost recorded in ledger",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "category": { "type": "string" },
        "description": { "type": "string" },
        "amount": { "type": "number" },
        "month": { "type": "string" }
      },
      "required": ["id", "category", "amount", "month"]
    },
    "PaymentLedger": {
      "title": "PaymentLedger",
      "description": "A receipt or balance payment registered in Barda finances",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "amount": { "type": "number" },
        "date": { "type": "string" },
        "type": { "type": "string" }
      },
      "required": ["id", "amount", "date"]
    }
  },
  "firestore": {
    "barda_users": {
      "schema": "User",
      "description": "Active registered user accounts"
    },
    "barda_invitations": {
      "schema": "Invitation",
      "description": "System registration invitations"
    },
    "barda_sales_orders": {
      "schema": "SalesOrder",
      "description": "List of confirmed customer sales and orders"
    },
    "barda_fixed_costs": {
      "schema": "FixedCost",
      "description": "Operational and recurring monthly fixed expenses"
    },
    "barda_payments_ledger": {
      "schema": "PaymentLedger",
      "description": "Historical financial entries ledger"
    },
    "barda_quotes_log": {
      "schema": { "$ref": "Quote" },
      "description": "Quotes logged by the client"
    },
    "barda_funnel_overrides": {
      "schema": { "$ref": "FunnelOverride" },
      "description": "Overrides to monthly funnel metric counts"
    },
    "barda_fabricacion_list": {
      "schema": { "$ref": "FabricationItem" },
      "description": "Workshop manufacturing tasks and items status"
    }
  }
}
